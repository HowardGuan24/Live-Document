{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Advisory AI explanation-video review",
  "type": "object",
  "required": ["reviewer", "scores", "detected_failures", "evidence", "confidence"],
  "properties": {
    "reviewer": {
      "type": "object",
      "required": ["provider", "model", "version"],
      "properties": {
        "provider": {"type": "string"},
        "model": {"type": "string"},
        "version": {"type": "string"}
      }
    },
    "scores": {
      "type": "object",
      "required": ["semantic_faithfulness", "explanation_clarity", "object_consistency", "camera_stability", "visual_simplicity", "loop_suitability"],
      "additionalProperties": false,
      "properties": {
        "semantic_faithfulness": {"type": "integer", "minimum": 1, "maximum": 5},
        "explanation_clarity": {"type": "integer", "minimum": 1, "maximum": 5},
        "object_consistency": {"type": "integer", "minimum": 1, "maximum": 5},
        "camera_stability": {"type": "integer", "minimum": 1, "maximum": 5},
        "visual_simplicity": {"type": "integer", "minimum": 1, "maximum": 5},
        "loop_suitability": {"type": "integer", "minimum": 1, "maximum": 5}
      }
    },
    "detected_failures": {"type": "array", "items": {"type": "string"}},
    "evidence": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  },
  "description": "AI judgments are advisory and are not ground truth."
}
